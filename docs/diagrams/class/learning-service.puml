@startuml
!theme plain

' === Group Service ===
interface IGroupService {
  + GetAllAsync(query, ct): Result<PagedResponse<GroupResponse>>
  + GetByIdAsync(id, ct): Result<GroupResponse>
  + CreateAsync(req, ct): Result<GroupResponse>
  + UpdateAsync(id, req, ct): Result<GroupResponse>
  + DeleteAsync(id, ct): Result
}

class GroupService {
  - db: AppDbContext
  + GetAllAsync(query, ct): Result<PagedResponse<GroupResponse>>
  + GetByIdAsync(id, ct): Result<GroupResponse>
  + CreateAsync(req, ct): Result<GroupResponse>
  + UpdateAsync(id, req, ct): Result<GroupResponse>
  + DeleteAsync(id, ct): Result
}

class GroupController {
  - service: IGroupService
  + GetAll(query, ct): ActionResult
  + GetById(id, ct): ActionResult
  + Create(req, ct): ActionResult
  + Update(id, req, ct): ActionResult
  + Delete(id, ct): ActionResult
}

